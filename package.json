{
  "name": "baromontres",
  "private": true,
  "version": "2.0.0",
  "description": "Bilingual price barometer for businessmontres.com — Cloudflare Pages + Workers + D1.",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev:web": "pnpm --filter @baromontres/web dev",
    "dev:cron": "pnpm --filter @baromontres/cron dev",
    "deploy:web": "pnpm --filter @baromontres/web deploy",
    "deploy:cron": "pnpm --filter @baromontres/cron deploy",
    "db:init:local": "wrangler d1 execute baromontres --local --file=migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute baromontres --remote --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  },
  "packageManager": "pnpm@9.12.3"
}
